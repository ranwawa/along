{
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!!**/.*/**",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/build",
      "!!**/coverage"
    ]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf",
    "attributePosition": "auto",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "expand": "auto",
    "trailingNewline": true,
    "useEditorconfig": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveLinesPerFunction": {
          "level": "error",
          "options": {
            "maxLines": 30,
            "skipBlankLines": true
          }
        }
      },
      "correctness": {
        "noUndeclaredVariables": "error",
        "noUnsafeFinally": "error",
        "noUnsafeOptionalChaining": "error",
        "noUnusedFunctionParameters": "error",
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "security": {
        "noGlobalEval": "error"
      },
      "nursery": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 300,
            "skipBlankLines": true
          }
        }
      },
      "style": {
        "noJsxLiterals": {
          "level": "error",
          "options": {
            "allowedStrings": [
              " ",
              ",",
              ".",
              ":",
              ";",
              "/",
              "\\",
              "|",
              "-",
              "_",
              "(",
              ")",
              "[",
              "]",
              "{",
              "}",
              "·",
              "•",
              " - ",
              " / ",
              " | ",
              " · ",
              " • ",
              "$",
              "¥",
              "￥",
              "€",
              "£"
            ]
          }
        },
        "noMagicNumbers": "error",
        "noNonNullAssertion": "error",
        "noParameterAssign": "error",
        "useImportType": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noImplicitAnyLet": "error",
        "noVar": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/__tests__/**"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "off"
          },
          "nursery": {
            "noExcessiveLinesPerFile": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "operatorLinebreak": "after"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "css": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "html": {
    "formatter": {
      "indentScriptAndStyle": false,
      "selfCloseVoidElements": "never",
      "whitespaceSensitivity": "css"
    }
  },
  "graphql": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
