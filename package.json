{
  "name": "@ranwawa/along-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "bun --filter @ranwawa/along dev:server",
    "dev:web": "bun --filter @ranwawa/along-web dev",
    "build:web": "bun --filter @ranwawa/along-web build",
    "test": "bun --filter @ranwawa/along test",
    "test:watch": "bun --filter @ranwawa/along test:watch",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "preinstall": "bun .along/git-hooks/preinstall.ts",
    "prepare": "git config core.hooksPath .along/git-hooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ranwawa/configurations.git"
  },
  "bugs": {
    "url": "https://github.com/ranwawa/configurations/issues"
  },
  "homepage": "https://github.com/ranwawa/configurations#readme",
  "author": "ranwawa <274544338@qq.com> (https://github.com/ranwawa)",
  "license": "ISC",
  "packageManager": "bun@1.3.11",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@ranwawa/along": "workspace:*",
    "@ranwawa/along-web": "workspace:*",
    "@ranwawa/biome-config": "workspace:*",
    "@ranwawa/preset": "workspace:*",
    "@ranwawa/preset-assets": "workspace:*"
  }
}
